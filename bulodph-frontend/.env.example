# API
VITE_API_URL=http://localhost:8000/api

# Demo accounts on login (explicitly enable only for demos)
VITE_DEMO_ACCOUNTS_ENABLED=false

# App version (shown in footer; optional, defaults to 1.0.0)
VITE_APP_VERSION=1.0.0

# Google Maps / Places API – for registration location (Philippines cities/provinces).
# Get key: https://console.cloud.google.com/ → APIs & Services → enable "Places API" → Credentials.
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Embed API – for footer & contact page map iframe (optional).
# Enable "Maps Embed API" in Cloud Console, then add key here to show the embedded map.
VITE_GOOGLE_MAPS_EMBED_KEY=
