APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Backend URL (used for avatar/storage links). Use port 8000 when using `php artisan serve`.
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Use MySQL so data persists (phpMyAdmin database). Do not use sqlite or data may appear to clear on restart.
# DB_DATABASE must match the database you use in phpMyAdmin (e.g. hpa_plus or bulodph) so profile avatars and admin client list use the same data.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bulodph
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
# Profile avatars are stored on the "public" disk (storage/app/public/avatars). Run: php artisan storage:link
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Brevo (SMTP + API). Use same SMTP key for BREVO_API_KEY if you only have one key.
# SMTP: smtp-relay.brevo.com:587 TLS; username = your Brevo login email.
BREVO_API_KEY=
# Set to false only on local Windows if you get cURL error 60 (SSL). Prefer setting php.ini curl.cainfo to cacert.pem.
# BREVO_SSL_VERIFY=false

# Payments (GCash/Maya). Set true only when gateway is wired in PaymentController.
PAYMENT_GATEWAY_ENABLED=false

# Security – production
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# CORS_SUPPORTS_CREDENTIALS=true
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
